menu "PluTO Firmware Configuration"

    config WIFI_SSID
        string "WiFi SSID"
        default ""
        help
            SSID of the WiFi network the device will join.

    config WIFI_PASSWORD
        string "WiFi password"
        default ""
        help
            Password of the WiFi network the device will join.

    config MQTT_BROKER_URI
        string "MQTT broker URI"
        default "mqtt://192.168.1.3:1883"
        help
            URI of the Mosquitto broker, for example mqtt://192.168.1.3:1883.

    config MQTT_BROKER_USERNAME
        string "MQTT broker username"
        default ""
        help
            Username used to authenticate against the MQTT broker.

    config MQTT_BROKER_PASSWORD
        string "MQTT broker password"
        default ""
        help
            Password used to authenticate against the MQTT broker.

    config MQTT_TOPIC_SUBSCRIPTION
        string "MQTT device registration topic"
        default "device/subscription"
        help
            Generic topic where the device publishes its user_id to request a control subscription.

    config NTP_SERVER
        string "NTP server"
        default "pool.ntp.org"
        help
            Hostname of the NTP server used to synchronize the ESP32 clock.

    config NTP_TIMEZONE
        string "Local timezone"
        default "UTC0"
        help
            POSIX timezone string applied after the clock is synchronized.

endmenu
